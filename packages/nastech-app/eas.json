{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1",
        "BUNDLE_TERMUX_BOOTSTRAP": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "credentialsSource": "remote",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1",
        "BUNDLE_TERMUX_BOOTSTRAP": "1"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1",
        "BUNDLE_TERMUX_BOOTSTRAP": "1"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
